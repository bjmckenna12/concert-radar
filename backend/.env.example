# Spotify OAuth — create app at https://developer.spotify.com/dashboard
SPOTIFY_CLIENT_ID=your_spotify_client_id_here
SPOTIFY_CLIENT_SECRET=your_spotify_client_secret_here
SPOTIFY_REDIRECT_URI=https://your-backend.railway.app/auth/callback

# App URLs
FRONTEND_URL=https://your-frontend.vercel.app
BACKEND_URL=https://your-backend.railway.app

# Security — generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=generate_a_random_secret_key_here

# Gmail SMTP — use an App Password (not your account password)
# Enable at: https://myaccount.google.com/apppasswords
SMTP_USER=your.gmail@gmail.com
SMTP_PASSWORD=your_gmail_app_password_here

# Database path (Railway persistent volume or local)
DB_PATH=concert_radar.db
